<?xml version="1.0" encoding="UTF-8"?>
<project>
    <fileVersion>3</fileVersion>
    <configuration>
        <name>Debug</name>
        <toolchain>
            <name>ARM</name>
        </toolchain>
        <debug>1</debug>
        <settings>
            <name>General</name>
            <archiveVersion>3</archiveVersion>
            <data>
                <version>34</version>
                <wantNonLocal>1</wantNonLocal>
                <debug>1</debug>
                <option>
                    <name>ExePath</name>
                    <state>Debug\Exe</state>
                </option>
                <option>
                    <name>ObjPath</name>
                    <state>Debug\Obj</state>
                </option>
                <option>
                    <name>ListPath</name>
                    <state>Debug\List</state>
                </option>
                <option>
                    <name>GEndianMode</name>
                    <state>0</state>
                </option>
                <option>
                    <name>GeneralEnableMisra</name>
                    <state>0</state>
                </option>
                <option>
                    <name>GeneralMisraVerbose</name>
                    <state>0</state>
                </option>
                <option>
                    <name>OGChipSelectEditMenu</name>
                    <state>MCXA153VLH	NXP MCXA153VLH</state>
                </option>
                <option>
                    <name>OGCoreOrChip</name>
                    <state>1</state>
                </option>
            </data>
        </settings>
        <settings>
            <name>ICCARM</name>
            <archiveVersion>2</archiveVersion>
            <data>
                <version>36</version>
                <wantNonLocal>1</wantNonLocal>
                <debug>1</debug>
                <option>
                    <name>CCDefines</name>
                    <state>CPU_MCXA153VLH</state>
                    <state>__STARTUP_CLEAR_BSS</state>
                </option>
                <option>
                    <name>CCIncludePath2</name>
                    <state>$PROJ_DIR$\..\src</state>
                    <state>$PROJ_DIR$\..\inc</state>
                    <state>$PROJ_DIR$\..\device</state>
                    <state>$PROJ_DIR$\..\device\periph</state>
                    <state>$PROJ_DIR$\..\drivers</state>
                    <state>$PROJ_DIR$\..\CMSIS\Include</state>
                </option>
                <option>
                    <name>CCOptLevel</name>
                    <state>3</state>
                </option>
                <option>
                    <name>CCOptStrategy</name>
                    <version>0</version>
                    <state>0</state>
                </option>
                <option>
                    <name>CCOptLevelSlave</name>
                    <state>3</state>
                </option>
            </data>
        </settings>
        <settings>
            <name>AARM</name>
            <archiveVersion>2</archiveVersion>
            <data>
                <version>11</version>
                <wantNonLocal>1</wantNonLocal>
                <debug>1</debug>
                <option>
                    <name>ADefines</name>
                    <state>__STARTUP_CLEAR_BSS</state>
                </option>
            </data>
        </settings>
        <settings>
            <name>ILINK</name>
            <archiveVersion>0</archiveVersion>
            <data>
                <version>22</version>
                <wantNonLocal>1</wantNonLocal>
                <debug>1</debug>
                <option>
                    <name>IlinkIcfFile</name>
                    <state>$PROJ_DIR$\MCXA153_flash.icf</state>
                </option>
                <option>
                    <name>IlinkOutputFile</name>
                    <state>IARTemplate.out</state>
                </option>
            </data>
        </settings>
    </configuration>
    <group>
        <name>Application</name>
        <file>
            <name>$PROJ_DIR$\..\src\main.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\serial_communication.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\serial.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\lpuart2.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\fifo.c</name>
        </file>
    </group>
    <group>
        <name>Board</name>
        <file>
            <name>$PROJ_DIR$\..\src\board.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\clock_config.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\src\pin_mux.c</name>
        </file>
    </group>
    <group>
        <name>Device</name>
        <file>
            <name>$PROJ_DIR$\..\device\system_MCXA153.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\device\startup_MCXA153.s</name>
        </file>
    </group>
    <group>
        <name>Drivers</name>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_common.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_common_arm.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_clock.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_reset.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_gpio.c</name>
        </file>
        <file>
            <name>$PROJ_DIR$\..\drivers\fsl_spc.c</name>
        </file>
    </group>
</project>
